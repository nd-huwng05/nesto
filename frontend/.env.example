# --- Local development ---
EXPO_PUBLIC_USE_LOCAL_API=true
EXPO_PUBLIC_DEV_API_PORT=8000
# Android emulator → 10.0.2.2 | iOS simulator → 127.0.0.1 (default, no change needed)
EXPO_PUBLIC_DEV_API_HOST_IOS=127.0.0.1
EXPO_PUBLIC_DEV_API_HOST_ANDROID=10.0.2.2
# Physical device (iPhone/Android on same WiFi as PC):
# 1) python manage.py print_dev_network
# 2) python manage.py runserver 0.0.0.0:8000
# 3) Uncomment and set your PC LAN IP (Expo may auto-detect via hostUri if unset):
# EXPO_PUBLIC_DEV_API_HOST=192.168.1.10

# --- Production (EXPO_PUBLIC_USE_LOCAL_API=false) ---
EXPO_PUBLIC_API_URL=https://api.nesto.com/api/v1
EXPO_PUBLIC_OAUTH_URL=https://api.nesto.com/o
EXPO_PUBLIC_CLIENT_ID=ggb9KpzfxhcaIof27VOtdTkLA5puE3J0tNsU68KO
EXPO_PUBLIC_WS_URL=wss://api.nesto.com

EXPO_PUBLIC_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com
EXPO_PUBLIC_IOS_CLIENT_ID=your-ios-client-id.apps.googleusercontent.com
EXPO_PUBLIC_ANDROID_CLIENT_ID=your-android-client-id.apps.googleusercontent.com

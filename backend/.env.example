# Django Settings
SECRET_KEY=your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0
# Physical device testing: run `python manage.py runserver 0.0.0.0:8000` and `python manage.py print_dev_network`

# Database Configuration
DB_ENGINE=django.db.backends.mysql
DB_NAME=nesto
DB_USER=nesto
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=3306

# Redis (production / server deploy). Dev local không cần — WebSocket dùng in-memory.
REDIS_URL=redis://localhost:6379/0
# CHANNEL_LAYER_REDIS=true   # chỉ bật khi có Redis local cho WebSocket
# USE_REDIS_CACHE=true       # chỉ bật khi muốn cache/session qua Redis

# Email Configuration (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@nesto.local

# SendGrid Configuration (use placeholders — never commit real keys)
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM=noreply@yourdomain.com

# Cloudinary (optional, for image uploads)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# OAuth2 password grant (must match frontend EXPO_PUBLIC_CLIENT_ID)
OAUTH_CLIENT_ID=ggb9KpzfxhcaIof27VOtdTkLA5puE3J0tNsU68KO

# Google Sign-In (Web + iOS + Android client IDs)
GOOGLE_OAUTH2_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com
GOOGLE_OAUTH2_CLIENT_IDS=your-google-web-client-id.apps.googleusercontent.com,your-android-client-id.apps.googleusercontent.com

# MoMo Payment (test: https://test-payment.momo.vn | prod: https://payment.momo.vn)
PAYMENTS_SANDBOX=true
MOMO_PARTNER_CODE=your-momo-partner-code
MOMO_ACCESS_KEY=your-momo-access-key
MOMO_SECRET_KEY=your-momo-secret-key
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=https://your-public-domain/payments/momo/return
MOMO_IPN_URL=https://your-public-api.com/api/v1/payments/momo/ipn/

# ZaloPay Payment (sandbox: sb-openapi.zalopay.vn | prod: openapi.zalopay.vn)
ZALOPAY_APP_ID=your-zalopay-app-id
ZALOPAY_KEY1=your-zalopay-key1
ZALOPAY_KEY2=your-zalopay-key2
ZALOPAY_APP_USER=nesto_guest
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create
ZALOPAY_REDIRECT_URL=https://your-public-domain/payments/zalopay/return
